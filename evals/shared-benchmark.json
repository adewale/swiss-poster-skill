    {
      "id": "pos-poster-composition",
      "split": "tune",
      "kind": "style-output",
      "prompt": "Create an implementable Tailwind/HTML Swiss-poster hero section, not an SVG-only poster. Include mega type, a 12-column grid, deliberate overlap and bleed, default Swiss red (#C8102E) as the only accent, no horizontal scroll at 320px, and a 44px-safe CTA.",
      "expected_behavior": [
        "Return Tailwind/HTML or CSS that applies the poster rules concretely rather than a standalone SVG.",
        "Evidence one accent, clipped bleed/no horizontal scroll, extreme scale, 12-column grid, and mobile/accessibility boundaries."
      ],
      "assertions": [
        {
          "name": "tailwind-poster-contract",
          "type": "contains_all",
          "values": [
            "grid-cols-12",
            "text-[clamp(",
            "leading-[0.85]",
            "#C8102E"
          ]
        },
        {
          "name": "poster-scroll-guard",
          "type": "contains_any",
          "values": [
            "overflow-hidden",
            "overflow-x-hidden",
            "overflow-clip"
          ]
        },
        {
          "name": "default-single-accent",
          "type": "contains_any",
          "values": [
            "one accent",
            "single accent",
            "only accent"
          ],
          "description": "Must explicitly constrain to one/single/only accent."
        },
        {
          "name": "mobile-boundary",
          "type": "contains_any",
          "values": [
            "no horizontal scroll",
            "prevent 320px horizontal scroll",
            "prevents 320px horizontal scroll",
            "320px horizontal scroll",
            "overflow-x-hidden"
          ],
          "description": "Must mention or implement 320px/no-horizontal-scroll safety."
        },
        {
          "name": "extreme-scale-code",
          "type": "contains_all",
          "values": [
            "text-[clamp(",
            "text-[11px]"
          ]
        },
        {
          "name": "not-svg-only",
          "type": "not_regex",
          "pattern": "(?is)(save as [^\\n]*\\.svg|```\\s*svg)"
        },
        {
          "name": "qualitative-review",
          "type": "judge",
          "rubric": [
            "Poster energy from scale/overlap/bleed, not generic minimalism",
            "Single-accent discipline",
            "No horizontal scroll at 320px with accessible touch targets"
          ]
        },
        {
          "name": "accent-token-present",
          "type": "contains_any",
          "values": [
            "#C8102E",
            "--poster-accent",
            "--accent"
          ],
          "description": "Must use the Swiss red accent or a semantic accent token."
        }
      ],
      "tags": []
    },
